o<clamptool> sub

M65 P2 ; clamp the tool

(PRINT, Requested tool is #<_selected_tool>)
    
G4 P0.5
M66 P5 L3 Q2 ; check the clamped tool sensor

o100 if [#5399 LT 0]
    o110 if [#<_selected_tool> GT 0]
        (abort, Failed to clamp tool) ; abort if the sensor does not activate in 2 seconds
    o110 else
o100 endif

o<clamptool> endsub [1]

M2
